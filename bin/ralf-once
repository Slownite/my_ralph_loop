#!/usr/bin/env bash
set -euo pipefail

MODEL="claude-sonnet-4-6"
ISSUE_NUM_ARG=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      echo "Usage: ralf-once [--model <model>] [<issue-number>]"
      echo "  Work on a single ralf-labelled GitHub issue with human-in-the-loop checkpoints."
      echo "  If no issue number is given, lists open ralf issues and prompts interactively."
      echo "  --model  Claude model to use (default: claude-sonnet-4-6)"
      exit 0
      ;;
    --model) MODEL="$2"; shift 2 ;;
    --) shift; break ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) ISSUE_NUM_ARG="$1"; shift ;;
  esac
done

# RALF_ROOT is injected by the Nix build, or resolved relative to this script for dev.
RALF_ROOT="${RALF_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
  C_RED=$'\033[31m'; C_YELLOW=$'\033[33m'; C_CYAN=$'\033[36m'
else
  C_RESET=''; C_BOLD=''; C_RED=''; C_YELLOW=''; C_CYAN=''
fi
LP="${C_BOLD}${C_CYAN}ralf-once:${C_RESET}"
LP_ERR="${C_BOLD}${C_RED}ralf-once:${C_RESET}"

PROMPT_FILE="$RALF_ROOT/prompts/ralf-issue.md"
if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "$LP_ERR prompt file not found: $PROMPT_FILE" >&2
  exit 1
fi

# Resolve issue number interactively if not provided.
if [[ -z "$ISSUE_NUM_ARG" ]]; then
  echo "${C_BOLD}Open ralf issues:${C_RESET}"
  gh issue list --label ralf --state open --json number,title \
    --jq '.[] | "  #\(.number)  \(.title)"'
  echo ""
  printf '%sIssue number to work:%s ' "$C_BOLD" "$C_RESET"
  read -r ISSUE_NUM
else
  ISSUE_NUM="$ISSUE_NUM_ARG"
fi

ISSUE_JSON=$(gh issue view "$ISSUE_NUM" --json number,title,body)
ISSUE_TITLE=$(echo "$ISSUE_JSON" | jq -r '.title')
ISSUE_BODY=$(echo "$ISSUE_JSON" | jq -r '.body')

echo "$LP working issue ${C_YELLOW}#$ISSUE_NUM${C_RESET} — ${C_BOLD}$ISSUE_TITLE${C_RESET}"

HITL_PREFIX="$(cat <<HITL
# ralf-once — Human-in-the-loop mode

You are working on issue #${ISSUE_NUM}: ${ISSUE_TITLE}

## Issue body

${ISSUE_BODY}

## HITL checkpoints — you MUST pause and wait for approval before proceeding

**Checkpoint 1 — Plan**
Before writing any code or tests, present:
- Which acceptance criteria map to which test cases
- Which modules/files you will create or modify
- The branch name you will use (ralf/issue-${ISSUE_NUM}-<slug>)
Then output:
  [ralf-once] Checkpoint 1: Plan ready. Type 'approve' to continue or describe changes.
Wait for the user to type 'approve' before proceeding.

**Checkpoint 2 — RED**
After writing the failing tests (before any implementation), show:
- The test file(s) with all failing tests
- The test runner output confirming they fail
Then output:
  [ralf-once] Checkpoint 2: Tests written (RED). Type 'approve' to continue or describe changes.
Wait for the user to type 'approve' before proceeding.

**Checkpoint 3 — GREEN**
After implementation passes all tests, show:
- \`git diff\` of all changed files
- The test runner output confirming they pass
- The type checker output confirming it passes
Then output:
  [ralf-once] Checkpoint 3: Implementation ready (GREEN). Type 'approve' to open PR and merge.
Wait for the user to type 'approve' before opening a PR.

## Playbook

After all three checkpoints are approved, follow the ralf playbook below exactly.
Use branch naming: ralf/issue-${ISSUE_NUM}-<slugified-title>
Do NOT auto-merge — open the PR and stop. The human will merge.

---

HITL
)"

PLAYBOOK="$(cat "$PROMPT_FILE")"

PROGRESS=""
if [[ -f ralf-progress.txt ]]; then
  PROGRESS="$(printf '\n\n---\n# Previous progress (ralf-progress.txt)\n\n'; cat ralf-progress.txt)"
fi

exec claude --model "$MODEL" "${HITL_PREFIX}

${PLAYBOOK}${PROGRESS}"
