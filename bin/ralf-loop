#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: ralf-loop <max-iterations>"
  echo "  Run up to <max-iterations> autonomous ralf cycles, one open issue per cycle."
  exit 0
fi

if [[ -z "${1:-}" ]]; then
  echo "Usage: ralf-loop <max-iterations>" >&2
  exit 1
fi

MAX="$1"

# Locate ralf installation root — works both from the repo and when installed via Nix.
# When installed via Nix, RALF_ROOT is injected by the flake before this script body.
RALF_ROOT="${RALF_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

# shellcheck disable=SC1091
source "$RALF_ROOT/lib/sandbox.sh"
# shellcheck disable=SC1091
source "$RALF_ROOT/lib/guard.sh"

PROMPT_FILE="$RALF_ROOT/prompts/ralf-issue.md"
if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "ralf-loop: prompt file not found: $PROMPT_FILE" >&2
  exit 1
fi

PROJECT_DIR="$(pwd)"

build_prompt() {
  printf '# Issue #%s: %s\n\n## Issue body\n\n%s\n\n---\n\n' \
    "$ISSUE_NUM" "$ISSUE_TITLE" "$ISSUE_BODY"
  cat "$PROMPT_FILE"
  if [[ -f "$PROJECT_DIR/ralf-progress.txt" ]]; then
    printf '\n\n---\n# Previous progress (ralf-progress.txt)\n\n'
    cat "$PROJECT_DIR/ralf-progress.txt"
  fi
}

for ((i=1; i<=MAX; i++)); do
  echo "ralf-loop: --- iteration $i/$MAX ---"

  echo "ralf-loop: fetching oldest open ralf issue..."
  ISSUE_JSON=$(gh issue list --label ralf --state open --json number,title,body \
    --jq 'sort_by(.number) | .[0]')

  if [[ -z "$ISSUE_JSON" || "$ISSUE_JSON" == "null" ]]; then
    echo "ralf-loop: no open ralf issues found — all complete after $((i-1)) iteration(s)."
    echo "<promise>COMPLETE</promise>"
    exit 0
  fi

  ISSUE_NUM=$(echo "$ISSUE_JSON" | jq -r '.number')
  ISSUE_TITLE=$(echo "$ISSUE_JSON" | jq -r '.title')
  ISSUE_BODY=$(echo "$ISSUE_JSON" | jq -r '.body')
  echo "ralf-loop: picked issue #$ISSUE_NUM — $ISSUE_TITLE"

  echo "ralf-loop: launching claude in sandbox for issue #$ISSUE_NUM..."
  _tmpout=$(mktemp)
  sandbox_run "$PROJECT_DIR" claude --dangerously-skip-permissions -p "$(build_prompt)" >"$_tmpout" 2>&1 &
  _pid=$!
  _spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  _i=0
  _start=$SECONDS
  while kill -0 "$_pid" 2>/dev/null; do
    printf '\r  %s  issue #%s — %ds elapsed' \
      "${_spin:$(( _i % ${#_spin} )):1}" "$ISSUE_NUM" "$(( SECONDS - _start ))"
    _i=$(( _i + 1 ))
    sleep 0.1
  done
  printf '\r\033[K'
  wait "$_pid" || true
  cat "$_tmpout"
  rm -f "$_tmpout"
  echo "ralf-loop: claude finished for issue #$ISSUE_NUM ($(( SECONDS - _start ))s)"

  # External guard: fetch remote and check the most recent ralf branch for deleted test files.
  echo "ralf-loop: fetching remote to check guard..."
  git -C "$PROJECT_DIR" fetch origin --quiet 2>/dev/null || true
  RALF_BRANCH=$(git -C "$PROJECT_DIR" branch -r --list "origin/ralf/issue-*" 2>/dev/null \
    | sed 's|origin/||' | sort | tail -1 | xargs || true)

  if [[ -n "$RALF_BRANCH" ]]; then
    echo "ralf-loop: running guard on branch $RALF_BRANCH..."
    if ! guard_test_deletion "$PROJECT_DIR" "main" 2>/dev/null; then
      echo "ralf-loop: guard failed — test files deleted on branch $RALF_BRANCH" >&2
      BLOCKED_NUM=$(echo "$RALF_BRANCH" | grep -oE 'issue-[0-9]+' | grep -oE '[0-9]+' || true)
      if [[ -n "$BLOCKED_NUM" ]]; then
        gh issue edit "$BLOCKED_NUM" --add-label ralf-blocked --remove-label ralf 2>/dev/null || true
        echo "ralf-loop: labelled issue #$BLOCKED_NUM as ralf-blocked" >&2
      fi
      exit 1
    fi
    echo "ralf-loop: guard passed for branch $RALF_BRANCH"
  else
    echo "ralf-loop: no ralf branch found on remote, skipping guard"
  fi
done

echo "ralf-loop: reached max iterations ($MAX) without completing all issues."
